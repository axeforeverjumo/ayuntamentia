# === Supabase (existing on server) ===
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/postgres

# === Qdrant (existing on server) ===
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=ayuntamentia_puntos

# === OpenClaw (existing on server) ===
OPENCLAW_BASE_URL=http://localhost:4200/v1
OPENCLAW_MODEL_MINI=gpt-5.4-mini
OPENCLAW_MODEL_FULL=gpt-5.4

# === Redis (for Celery) ===
REDIS_URL=redis://localhost:6379/0

# === Pipeline / internal service wiring ===
PDF_STORAGE_PATH=/data/pdfs
API_INTERNAL_URL=http://localhost:8050
ALERT_RULES_CRON_TOKEN=
REPUTACIO_LLM_SENTIMENT=1
OPENCLAW_PROXY_URL=http://127.0.0.1:10531/v1
OPENCLAW_MODEL_FAST=gpt-5.4

# === Parlament de Catalunya ===
