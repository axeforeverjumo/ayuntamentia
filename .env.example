# === App ===
PARTY_NAME=ALIANÇA CATALANA
BACKFILL_RATE_PER_MINUTE=2
BACKFILL_YEARS=5

# === Multi-tenant: configuración del CLIENTE (partido que usa la herramienta) ===
# Estas variables definen el POV de los prompts del chat, las preguntas de los
# modos políticos y el branding ("L'arma política de X"). Cambia sólo estas para
# redesplegar el producto a otro partido (PP, PSOE, ERC, JxCat, etc.).
#
# Valores válidos para CLIENT_PARTIDO: AC, PP, PSC, ERC, JxCat, CUP, VOX, Cs, Comuns
# CLIENT_RIVALES: lista CSV opcional (si no se pone, se infiere del partido).
CLIENT_PARTIDO=AC
CLIENT_NOMBRE=Aliança Catalana
CLIENT_RIVALES=
# Ejemplos de config para otros clientes:
#   CLIENT_PARTIDO=PP
#   CLIENT_NOMBRE=Partit Popular
#   CLIENT_RIVALES=PSC,ERC,JxCat,VOX,CUP,Cs
#
#   CLIENT_PARTIDO=PSC
#   CLIENT_NOMBRE=Partit dels Socialistes de Catalunya
#   CLIENT_RIVALES=ERC,JxCat,PP,CUP,VOX,Cs
